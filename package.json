{
  "name": "astro-paper",
  "type": "module",
  "version": "5.4.0",
  "scripts": {
    "dev": "astro dev",
    "dev:generate-rss": "chokidar \"src/data/blog/**/*.{md,mdx}\" -c \"node scripts/generate-rss.mjs\"",
    "build": "astro check && astro build && node scripts/generate-rss.mjs && pagefind --site dist && cp -r dist/pagefind public/",
    "build:win": "astro check && astro build && node scripts/generate-rss.mjs && pagefind --site dist && node scripts/copy-pagefind.mjs",
    "build:ebook": "node scripts/generate-ebook.mjs",
    "build:epub": "node scripts/generate-ebook.mjs && node scripts/generate-epub.mjs",
    "build:epub2": "node scripts/generate-ebook.mjs && node scripts/generate-epub.mjs --version=2",
    "build:pdf": "node scripts/generate-ebook.mjs && node scripts/generate-pdf.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "lint": "eslint ."
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.14",
    "@astrojs/react": "^4.3.0",
    "@astrojs/rss": "^4.0.12",
    "@astrojs/sitemap": "^3.4.1",
    "@giscus/react": "^3.1.0",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.1.8",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "astro": "^5.9.2",
    "astro-social-share": "^2.2.0",
    "dayjs": "^1.11.13",
    "fuse.js": "^7.1.0",
    "gray-matter": "^4.0.3",
    "lodash.kebabcase": "^4.1.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "rehype-stringify": "^10.0.1",
    "remark-collapse": "^0.1.2",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "remark-toc": "^9.0.0",
    "sanitize-html": "^2.17.4",
    "satori": "^0.15.2",
    "sharp": "^0.34.2",
    "tailwindcss": "^4.1.8",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@pagefind/default-ui": "^1.3.0",
    "@shikijs/transformers": "^3.6.0",
    "@tailwindcss/typography": "^0.5.16",
    "@types/lodash.kebabcase": "^4.1.9",
    "@types/sanitize-html": "^2.16.1",
    "@typescript-eslint/parser": "^8.34.0",
    "chokidar-cli": "^3.0.0",
    "eslint": "^9.28.0",
    "eslint-plugin-astro": "^1.3.1",
    "epub-gen-memory": "^1.1.2",
    "globals": "^16.2.0",
    "marked": "^18.0.3",
    "pagefind": "^1.3.0",
    "playwright": "^1.60.0",
    "prettier": "^3.5.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.6.12",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.0"
  },
  "engines": {
    "node": ">=20.0.0 <21.0.0"
  }
}
